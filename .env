# ============================================================================
# ARCHIVO DE EJEMPLO: .env
# ============================================================================
#
# INSTRUCCIONES:
# 1. Renombra este archivo a: .env (sin el .example)
# 2. Reemplaza los valores con tu información de Neon
# 3. NUNCA hagas commit de este archivo a Git (ya está en .gitignore)
#
# CÓMO OBTENER TU DATABASE_URL:
# 1. Ve a https://console.neon.tech
# 2. Abre tu proyecto
# 3. Connection details → Direct Connection
# 4. Copia la URL postgresql://...
#
# ============================================================================

# DATABASE_URL - Tu conexión a Neon (Direct Connection, no Pooler)
# Formato: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
#
# EJEMPLO:
# DATABASE_URL=postgresql://neon_user:abc123xyz@ep-cool-bird-12345.us-east-2.aws.neon.tech/neon_db?sslmode=require

DATABASE_URL=postgresql://neondb_owner:npg_y2lGCWhAc9rj@ep-red-pine-aiww3s9a.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require


# ============================================================================
# NOTAS IMPORTANTES:
# ============================================================================
#
# ✓ SIEMPRE usa "Direct Connection", NO "Pooled Connection"
#   - Pooled: para aplicaciones web
#   - Direct: para ETL, scripts, Jupyter (LO QUE USAMOS)
#
# ✓ El protocolo SIEMPRE es: postgresql:// (no postgres://)
#
# ✓ El final SIEMPRE incluye: ?sslmode=require
#
# ✓ Si tu contraseña tiene caracteres especiales (!, @, #, etc.):
#   - URL-encódea: ! = %21, @ = %40, # = %23
#   - Ejemplo: pass!word@123 → pass%21word%40123
#
# ✓ NO dejes espacios alrededor del = (no: DATABASE_URL = value)
#
# ============================================================================

# EJEMPLO DE CÓMO SE VE UNA URL REAL:
# DATABASE_URL=postgresql://neondb_owner:7a3b9d8e2c1f@ep-polished-mountain-45678.us-east-2.aws.neon.tech/neondb?sslmode=require

# ============================================================================
